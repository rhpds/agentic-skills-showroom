{"nodes": [{"id": "plans_2026_05_05_skills_course", "label": "Skills Course Implementation Plan", "file_type": "document", "source_file": "docs/superpowers/plans/2026-05-05-skills-course.md", "source_location": null, "source_url": null, "captured_at": "2026-05-18", "author": null, "contributor": null}, {"id": "showroom_skills_course_abstract_writer", "label": "abstract-writer Skill", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-05-05-skills-course.md", "source_location": "Task 4", "source_url": null, "captured_at": "2026-05-18", "author": null, "contributor": null, "rationale": "Hand-built skill for generating conference talk abstracts. Teaches skill anatomy (frontmatter, body, templates). Demonstrates the instruction + supporting files complexity level."}, {"id": "showroom_skills_course_conf_finder", "label": "conf-finder Skill", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-05-05-skills-course.md", "source_location": "Task 5", "source_url": null, "captured_at": "2026-05-18", "author": null, "contributor": null, "rationale": "Generated via skill-creator meta-skill then refined. Teaches the difference between generated and hand-crafted skills and the refinement process."}, {"id": "showroom_skills_course_trip_report", "label": "trip-report Skill", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-05-05-skills-course.md", "source_location": "Task 6", "source_url": null, "captured_at": "2026-05-18", "author": null, "contributor": null, "rationale": "Most complex skill with executable components (Python formatting script). Demonstrates the skill-with-scripts complexity level."}, {"id": "showroom_skills_course_conference_toolkit", "label": "conference-toolkit Marketplace", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-05-05-skills-course.md", "source_location": "Task 6", "source_url": null, "captured_at": "2026-05-18", "author": null, "contributor": null, "rationale": "The bundled marketplace containing all three conference skills. Teaches plugin packaging, marketplace.json, plugin.json, namespacing, and git-based distribution."}, {"id": "showroom_skills_course_skill_creator", "label": "skill-creator Meta-Skill", "file_type": "concept", "source_file": "docs/superpowers/plans/2026-05-05-skills-course.md", "source_location": "Task 5", "source_url": "https://github.com/anthropics/skills/blob/main/skills/skill-creator/SKILL.md", "captured_at": "2026-05-18", "author": null, "contributor": null, "rationale": "A skill that creates other skills. First exposure to meta-skills concept and the Anthropic official marketplace."}, {"id": "showroom_skills_course_progressive_disclosure", "label": "Progressive Disclosure (Skill Loading Model)", "file_type": "rationale", "source_file": "docs/superpowers/plans/2026-05-05-skills-course.md", "source_location": "Task 4, Section: Progressive Disclosure", "source_url": null, "captured_at": "2026-05-18", "author": null, "contributor": null, "rationale": "Two-phase loading: frontmatter (name+description) always in context, full body loaded only on activation. Design trade-off between always-available skill awareness and token efficiency."}, {"id": "showroom_skills_course_skill_md", "label": "SKILL.md File Convention", "file_type": "rationale", "source_file": "docs/superpowers/plans/2026-05-05-skills-course.md", "source_location": "Task 4, Section: Skill Anatomy", "source_url": null, "captured_at": "2026-05-18", "author": null, "contributor": null, "rationale": "Convention for skill packaging: YAML frontmatter (name, description) + markdown body instructions. Evolved from Cursor's single .cursorrules file to directory-based, multi-scope, composable format."}, {"id": "showroom_skills_course_skill_complexity_spectrum", "label": "Skill Complexity Spectrum", "file_type": "rationale", "source_file": "docs/superpowers/plans/2026-05-05-skills-course.md", "source_location": "Task 5, Section: Skill Complexity Spectrum", "source_url":